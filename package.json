{
  "name": "@logicseek/hello-cc",
  "version": "0.1.6",
  "description": "Local control plane for coordinating Claude Code, Codex, and other coding CLI sessions.",
  "type": "module",
  "bin": {
    "hcc": "bin/hcc.mjs",
    "hello-cc": "bin/hcc.mjs"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "assets/",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs/"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "release:notes": "node ./scripts/release-notes.mjs",
    "release:check": "node ./scripts/release-notes.mjs --check",
    "release:github": "node ./scripts/github-release.mjs",
    "release:github:dry-run": "node ./scripts/github-release.mjs --dry-run",
    "smoke": "node ./bin/hcc.mjs --help",
    "test": "node ./scripts/regression.mjs",
    "test:regression": "node ./scripts/regression.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dullne/hello-cc.git"
  },
  "homepage": "https://github.com/Dullne/hello-cc#readme",
  "bugs": {
    "url": "https://github.com/Dullne/hello-cc/issues"
  },
  "keywords": [
    "claude-code",
    "codex",
    "cli",
    "terminal",
    "peer-mesh",
    "coordination",
    "multi-agent",
    "session-management",
    "tmux",
    "xterm"
  ],
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0"
  },
  "license": "Apache-2.0"
}
